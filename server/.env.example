# Backend Environment Variables
# Copy this file to .env for local development

PORT=3001
NODE_ENV=development

# HTTPS for local dev (production uses Render's TLS)
USE_HTTPS=false

# Email config (support tickets). Leave blank locally — tickets log to console.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=Dashboard Support <noreply@example.com>

# Gmail example:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
