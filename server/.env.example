# Backend Environment Variables
# Copy this file to .env for local development

# Server Port
PORT=3001

# JWT Secret Key (change this in production!)
JWT_SECRET=your-secret-key-change-this-in-production

# Node Environment
NODE_ENV=development

# HTTPS Configuration
# Set to 'true' to enable HTTPS for local development
# Requires SSL certificates (run: npm run generate-certs)
USE_HTTPS=false

# For production, HTTPS will be handled by your hosting platform (e.g., Render.com)

# Email Configuration (for support tickets and MFA)
# Leave these blank for development (emails will be logged to console)
# For production, configure SMTP settings (e.g., Gmail, SendGrid, etc.)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=CchdDash Support <noreply@cchddash.com>

# Gmail Example:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
# Note: Use Gmail App Password, not your regular password
# Generate at: https://myaccount.google.com/apppasswords

# Master Admin Credentials (for emergency access)
# These credentials work independently of the database
# Set these ONLY in production environment (Render dashboard)
# DO NOT commit actual credentials to version control
MASTER_ADMIN_USERNAME=
MASTER_ADMIN_PASSWORD=
