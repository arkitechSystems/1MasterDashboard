# Backend Environment Variables
# Copy this file to .env for local development

PORT=3001
NODE_ENV=development

# HTTPS for local dev (production uses Render's TLS)
USE_HTTPS=false

# Email config (support tickets). Leave blank locally — tickets log to console.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=Dashboard Support <noreply@example.com>

# Gmail example:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password

# ─── Database ───────────────────────────────────────────────────────────
# Local: defaults to server/database.sqlite if unset.
# Render: mount a persistent disk and point this at /var/data/db.sqlite
#         (or swap to Postgres by adding a DATABASE_URL handler in src/db.ts).
DATABASE_PATH=

# ─── Token encryption (Plaid access_tokens at rest) ─────────────────────
# 32 bytes = 64 hex chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required in production. Dev fallback prints a warning if unset.
TOKEN_ENCRYPTION_KEY=

# ─── Plaid ──────────────────────────────────────────────────────────────
# Leave PLAID_CLIENT_ID / PLAID_SECRET blank to run in mock mode — every
# Plaid endpoint returns realistic fake data so the frontend flow is
# testable without credentials. Fill these in when you're ready to connect.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Only required for OAuth-required institutions; leave blank for now.
PLAID_REDIRECT_URI=
