# Frontend Environment Variables
# Copy this file to .env for local development

# Backend API URL
# For HTTP (default local development):
REACT_APP_API_URL=http://localhost:3001

# For HTTPS (secure local development):
# REACT_APP_API_URL=https://localhost:3001

# Enable HTTPS for React dev server (optional)
# HTTPS=true
# Note: This uses a self-signed certificate. Your browser will show a warning.
